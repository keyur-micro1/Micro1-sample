<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TDS Certificate Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TdsCertificatePortal.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <div class="container-fluid app-header-inner">
            <a class="app-brand" asp-controller="Home" asp-action="Index">TDS Certificate Portal</a>
            <span class="app-context">ASP.NET Core MVC · IIS ready</span>
        </div>
    </header>
    <main class="container-fluid app-main" role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
